<div class="{{if @compare 'cf-content-compare' 'cf-content'}}">
  {{#if this.loading}}
    <div class="uk-text-center"><UkSpinner @ratio={{2}} /></div>
  {{else if this.document}}
    {{#let
      (hash
        document=this.document
        navigation=(component
          "cf-navigation"
          navigation=this.navigation
          useAsHeading=(or @useAsHeading false)
          headingBaseLevel=(or @headingBaseLevel 1)
          compare=@compare
        )
        pagination=(component "cf-pagination" navigation=this.navigation)
        form=(component
          "cf-form-wrapper"
          document=this.document
          fieldset=this.fieldset
          context=@context
          compare=@compare
          disabled=@disabled
          onSave=@onSave
        )
      )
      as |content|
    }}
      {{#if (has-block)}}
        {{yield content}}
      {{else if (gt this.document.fieldsets.length 1)}}
        <div uk-grid>
          <div class={{this.navigationWidth}}><content.navigation /></div>
          <div class="uk-width-expand">
            {{yield to="formHeader"}}
            <content.form ...attributes />
            <hr />
            <content.pagination />
          </div>
        </div>
      {{else}}
        <content.form ...attributes />
      {{/if}}
    {{/let}}
  {{else}}
    {{yield to="notfound"}}
  {{/if}}
</div>